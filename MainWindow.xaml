<Window x:Class="CustomBrowserWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="f1ldas's browser" Height="800" Width="1200" MinHeight="600" MinWidth="800">
    <DockPanel>

        <!-- Top Bar -->
        <Grid x:Name="TopBar" DockPanel.Dock="Top" Height="40" Background="#f0f0f0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left side: Grid instead of StackPanel so address bar can stretch -->
            <Grid VerticalAlignment="Center" Margin="5,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- buttons -->
                    <ColumnDefinition Width="*"/>
                    <!-- address bar stretches -->
                </Grid.ColumnDefinitions>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Button Content="+" Width="40" Click="NewTab_Click"/>
                    <Button Content="◀" Width="40" Click="BackButton_Click"/>
                    <Button Content="▶" Width="40" Click="ForwardButton_Click"/>
                    <Button Content="⟳" Width="40" Click="ReloadButton_Click"/>
                </StackPanel>

                <!-- Address Bar -->
                <Grid Grid.Column="1" HorizontalAlignment="Stretch" Margin="5,0,0,0">
                    <TextBox x:Name="AddressBar"
             VerticalAlignment="Center"
             VerticalContentAlignment="Center"
             Height="24"
             Padding="5,0"
             KeyDown="AddressBar_KeyDown"
             TextChanged="AddressBar_TextChanged"/>
                    <TextBlock x:Name="AddressPlaceholder"
               Text="Search or enter address"
               Foreground="Gray"
               Margin="6,0,0,0"
               VerticalAlignment="Center"
               IsHitTestVisible="False"/>
                    <Popup x:Name="SuggestionPopup"
           Placement="Bottom"
           PlacementTarget="{Binding ElementName=AddressBar}"
           StaysOpen="False">
                        <Border Background="White" BorderBrush="Gray" BorderThickness="1">
                            <ListBox x:Name="SuggestionList"
                     Width="Auto"
                     MouseDoubleClick="Suggestion_Click"/>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>

            <!-- Right Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0">
                <Button Content="Go" Width="60" Click="GoButton_Click" Margin="5,0,0,0"/>
                <Button Content="⚙ Settings" Width="80" Click="SettingsButton_Click" Margin="5,0,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Tab Control -->
        <TabControl x:Name="BrowserTabs" Margin="0" Background="White"/>
    </DockPanel>
</Window>