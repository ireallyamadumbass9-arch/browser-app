<Window x:Class="WpfInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Browser Installer" Height="280" Width="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Folder label -->
            <RowDefinition Height="Auto"/>
            <!-- Folder selection -->
            <RowDefinition Height="Auto"/>
            <!-- Allow Addons -->
            <RowDefinition Height="Auto"/>
            <!-- Progress bar -->
            <RowDefinition Height="Auto"/>
            <!-- Status label -->
            <RowDefinition Height="*"/>
            <!-- Spacer -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Install folder -->
        <TextBlock Text="Select installation folder:" FontWeight="Bold" Grid.Row="0"/>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,5,0,5">
            <TextBox x:Name="InstallPathBox" Width="400"/>
            <Button x:Name="BrowseButton" Content="Browse..." Margin="5,0,0,0" Click="Browse_Click"/>
        </StackPanel>

        <!-- Addons -->
        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,5,0,5" VerticalAlignment="Center">
            <CheckBox x:Name="AllowAddonsCheckbox" Content="Allow Addons" Checked="AllowAddons_Checked" Unchecked="AllowAddons_Unchecked"/>
            <TextBox x:Name="AddonCodeBox" Width="300" Margin="10,0,0,0" IsEnabled="False" Text=""/>
        </StackPanel>

        <!-- Progress -->
        <ProgressBar x:Name="InstallProgress" Grid.Row="3" Height="25" Minimum="0" Maximum="100" Margin="0,5,0,0"/>

        <!-- Status -->
        <Label x:Name="InstallStatusLabel" Grid.Row="4" Margin="0,5,0,0" Content="Ready"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" Grid.Row="6" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="InstallButton" Content="Install" Width="100" Click="Install_Click"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="100" Margin="10,0,0,0" Click="Cancel_Click" IsEnabled="False"/>
            <Button x:Name="FinishButton" Content="Finish" Width="100" Margin="10,0,0,0" Click="Finish_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>